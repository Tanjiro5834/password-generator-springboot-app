/mvnw text eol=lf
*.cmd text eol=crlf

# --- Force Java as primary ---
*.java linguist-detectable=true

# --- Completely suppress frontend from stats ---
*.html linguist-vendored=true
*.css linguist-vendored=true
*.js linguist-vendored=true

# --- Ignore minified / generated ---
*.min.js linguist-vendored=true
*.min.css linguist-vendored=true

# --- Thymeleaf templates specifically ---
/src/main/resources/templates/* linguist-vendored=true

# --- Static assets ---
/src/main/resources/static/* linguist-vendored=true

# --- Docs ---
*.md linguist-documentation=true